    "./mission-runner": "./src/mission-runner.mjs",
    "./control-plane": "./src/control-plane.mjs"
  },
  "bin": {
    "antimatterium-mission": "scripts/antimatterium-mission.mjs",
    "antimatterium-control": "./scripts/antimatterium-control.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "README.md",
    "LICENSE",
    "CHARTER_OF_ANTIMATTER_INDUSTRIALIZATION.md",
    "ANTIMATTERIUM_COMPLETION_RECEIPT.json",
    "ANTIMATTERIUM_CONTROL_SEAL.json",
    "custody/",
    "docs/",
    "examples/",
    "models/",
    "public/",
    "receipts/",
    "scripts/",
    "sources/",
    "src/",
    "standards/",
    "tests/"
  ]
