    "verify:receipts": "node scripts/verify-receipts.mjs",
    "verify:index": "node scripts/verify-public-index.mjs",
    "verify:seal": "node scripts/verify-control-seal.mjs",
    "verify:npm": "node scripts/verify-npm-publication.mjs",
    "verify:bindings": "node scripts/verify-cross-stack-bindings.mjs",
    "verify:invocorder-recognition": "node scripts/verify-invocorder-recognition.mjs",
    "verify:qvra-recognition": "node scripts/verify-qvra-lab-recognition.mjs",
    "verify:qvra-full-chain": "node scripts/verify-qvra-full-chain-recognition.mjs",
    "verify:npm-021": "node scripts/verify-npm-021-publication.mjs",
    "verify:privacy": "node scripts/verify-public-privacy-scan.mjs",
    "verify:claims": "node scripts/verify-claim-boundary-scan.mjs",
    "verify:control": "node scripts/verify-control-plane.mjs",
    "control:status": "node scripts/antimatterium-control.mjs status",
    "control:bundle": "node scripts/antimatterium-control.mjs bundle"
  },
  "exports": {
    "./annihilation-energy": "./src/annihilation-energy.mjs",
